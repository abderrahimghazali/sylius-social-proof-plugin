{
    "name": "abderrahimghazali/sylius-social-proof-plugin",
    "type": "sylius-plugin",
    "description": "Social proof and FOMO widgets for Sylius 2.x — live viewers, recent purchases, sales counter, low stock alerts",
    "license": "MIT",
    "keywords": ["sylius", "sylius-plugin", "social-proof", "fomo", "urgency", "live-viewers", "ecommerce"],
    "homepage": "https://github.com/abderrahimghazali/sylius-social-proof-plugin",
    "authors": [
        {
            "name": "Abderrahim Ghazali",
            "homepage": "https://github.com/abderrahimghazali"
        }
    ],
    "support": {
        "issues": "https://github.com/abderrahimghazali/sylius-social-proof-plugin/issues",
        "source": "https://github.com/abderrahimghazali/sylius-social-proof-plugin"
    },
    "require": {
        "php": "^8.2",
        "doctrine/orm": "^2.17 || ^3.0",
        "sylius/sylius": "^2.1",
        "symfony/cache": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/stimulus-bundle": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Abderrahim\\SyliusSocialProofPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Abderrahim\\SyliusSocialProofPlugin\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "sylius-plugin-name": "Social Proof Plugin"
    },
    "config": {
        "sort-packages": true
    }
}
