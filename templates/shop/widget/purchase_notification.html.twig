{# Recent purchase notifications — footer fallback for non-product pages #}
{# On product pages, this is rendered inside the product_badge.html.twig stack instead #}
{% if hookable_metadata.context.product is not defined %}
    {% set rp_settings = social_proof_widget_settings('recent_purchases') %}

    {% if rp_settings is not empty %}
        {% set display_position = rp_settings.display_position|default('bottom_right') %}
        {% set pos_styles = {
            'top_left': 'top:1.5rem;left:1.5rem;',
            'top_right': 'top:1.5rem;right:1.5rem;',
            'bottom_left': 'bottom:1.5rem;left:1.5rem;',
            'bottom_right': 'bottom:1.5rem;right:1.5rem;',
        } %}
        {% set pill = 'background:white;border-radius:8px;padding:0.5rem 0.875rem;box-shadow:0 2px 12px rgba(0,0,0,0.1);font-size:0.8125rem;color:#374151;display:flex;align-items:center;gap:0.5rem;' %}

        <div style="position:fixed;{{ pos_styles[display_position]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9998;">
            <div id="sp-notification" style="{{ pill }}display:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                    <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span id="sp-message"></span>
                <button onclick="spDismiss()" style="background:none;border:none;color:#9ca3af;cursor:pointer;font-size:1rem;padding:0;line-height:1;flex-shrink:0;">&times;</button>
            </div>
        </div>

        <script>
        (function() {
            var storageKey = 'sp_recent_purchases_shown';
            try { if (sessionStorage.getItem(storageKey)) return; } catch(e) {}

            var url = '{{ path('social_proof_shop_recent_purchases')|e('js') }}';
            var interval = {{ (rp_settings.display_interval|default(8)) * 1000 }};
            var max = {{ rp_settings.max_toasts|default(5) }};
            var purchases = [], idx = 0;
            var el = document.getElementById('sp-notification');
            if (!el) return;

            function timeAgo(d) {
                if (!d) return '';
                var diff = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
                if (diff < 1) return 'just now';
                if (diff < 60) return diff + 'm ago';
                var h = Math.floor(diff / 60);
                return h < 24 ? h + 'h ago' : Math.floor(h / 24) + 'd ago';
            }

            function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

            function show() {
                if (idx >= purchases.length || idx >= max) return;
                var p = purchases[idx];
                var city = p.city ? ' from ' + esc(p.city) : '';
                var name = esc(p.first_name || 'Someone');
                var msg = document.getElementById('sp-message');
                var time = timeAgo(p.purchased_at);
                var timeHtml = time ? ' <span style="color:#9ca3af;">' + esc(time) + '</span>' : '';
                var productUrl = p.product_slug ? '/' + encodeURI(p.locale + '/products/' + p.product_slug) : '';
                if (msg) {
                    var productHtml = productUrl
                        ? '<a href="' + esc(productUrl) + '" style="color:inherit;font-weight:600;text-decoration:underline;">' + esc(p.product_name) + '</a>'
                        : '<strong>' + esc(p.product_name) + '</strong>';
                    msg.innerHTML = name + city + ' just bought ' + productHtml + timeHtml;
                }
                el.style.display = 'flex';
                setTimeout(function() { el.style.display = 'none'; idx++; setTimeout(show, 2000); }, interval);
            }

            window.spDismiss = function() { el.style.display = 'none'; idx++; try { sessionStorage.setItem(storageKey, '1'); } catch(e) {} };

            fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                purchases = data;
                if (purchases.length > 0) { try { sessionStorage.setItem(storageKey, '1'); } catch(e) {} setTimeout(show, 3000); }
            }).catch(function() {});
        })();
        </script>
    {% endif %}
{% endif %}
