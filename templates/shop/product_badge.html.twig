{# Social proof product badge — fixed bottom-right overlay, non-intrusive #}
{% set product = hookable_metadata.context.product|default(null) %}

{% if product is not null %}
    {% set widgets = social_proof_widgets(product) %}
    {% set ctrl_prefix = '@abderrahimghazali/sylius-social-proof-plugin' %}
    {% set ctrl_ns = ctrl_prefix|replace({'@': '', '/': '--'}) %}

    {% if widgets|length > 0 %}
        <div id="social-proof-badge" style="
            position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9998;
            display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end;
        ">
            {% if widgets.live_viewers is defined %}
                <div style="
                    background: white; border-radius: 8px; padding: 0.5rem 0.875rem;
                    box-shadow: 0 2px 12px rgba(0,0,0,0.1); font-size: 0.8125rem; color: #374151;
                    display: flex; align-items: center; gap: 0.5rem;
                    animation: socialProofSlideIn 0.4s ease-out;
                "
                     data-controller="{{ ctrl_prefix }}/live-viewers"
                     data-{{ ctrl_ns }}--live-viewers-url-value="{{ path('social_proof_shop_live_viewers', {productId: product.id}) }}"
                     data-{{ ctrl_ns }}--live-viewers-interval-value="{{ (widgets.live_viewers.settings.refresh_interval|default(30)) * 1000 }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #3b82f6;">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                    <span>
                        <strong data-{{ ctrl_ns }}--live-viewers-target="count">{{ widgets.live_viewers.count }}</strong>
                        {{ 'social_proof.shop.people_viewing'|trans }}
                    </span>
                </div>
            {% endif %}

            {% if widgets.sales_counter is defined %}
                <div style="
                    background: white; border-radius: 8px; padding: 0.5rem 0.875rem;
                    box-shadow: 0 2px 12px rgba(0,0,0,0.1); font-size: 0.8125rem; color: #374151;
                    display: flex; align-items: center; gap: 0.5rem;
                    animation: socialProofSlideIn 0.4s ease-out 0.2s both;
                "
                     data-controller="{{ ctrl_prefix }}/sales-counter"
                     data-{{ ctrl_ns }}--sales-counter-count-value="{{ widgets.sales_counter.count }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #f59e0b;">
                        <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>
                    </svg>
                    <span>
                        <strong data-{{ ctrl_ns }}--sales-counter-target="count">0</strong>
                        {{ 'social_proof.shop.sold_recently'|trans({'%hours%': widgets.sales_counter.lookback_hours}) }}
                    </span>
                </div>
            {% endif %}

            {% if widgets.low_stock is defined %}
                <div style="
                    background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 0.5rem 0.875rem;
                    box-shadow: 0 2px 12px rgba(0,0,0,0.1); font-size: 0.8125rem; color: #dc2626; font-weight: 600;
                    display: flex; align-items: center; gap: 0.5rem;
                    animation: socialProofSlideIn 0.4s ease-out 0.4s both;
                "
                     data-controller="{{ ctrl_prefix }}/low-stock"
                     data-{{ ctrl_ns }}--low-stock-count-value="{{ widgets.low_stock.count }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                    <span>{{ 'social_proof.shop.only_left'|trans({'%count%': widgets.low_stock.count}) }}</span>
                </div>
            {% endif %}
        </div>

        <style>
            @keyframes socialProofSlideIn {
                from { opacity: 0; transform: translateX(20px); }
                to { opacity: 1; transform: translateX(0); }
            }
        </style>
    {% endif %}
{% endif %}
