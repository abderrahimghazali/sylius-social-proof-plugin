{# Social proof widgets — each independently positioned #}
{% set product = hookable_metadata.context.product|default(null) %}

{% if product is not null %}
    {% set widgets = social_proof_widgets(product) %}
    {% set rp_settings = social_proof_widget_settings('recent_purchases') %}
    {% set ctrl_prefix = '@abderrahimghazali/sylius-social-proof-plugin' %}
    {% set ctrl_ns = ctrl_prefix|replace({'@': '', '/': '--'}) %}
    {% set pill = 'background:white;border-radius:8px;padding:0.5rem 0.875rem;box-shadow:0 2px 12px rgba(0,0,0,0.1);font-size:0.8125rem;color:#374151;display:flex;align-items:center;gap:0.5rem;' %}
    {% set pos_css = {
        'top_left': 'top:1.5rem;left:1.5rem;',
        'top_right': 'top:1.5rem;right:1.5rem;',
        'bottom_left': 'bottom:1.5rem;left:1.5rem;',
        'bottom_right': 'bottom:1.5rem;right:1.5rem;',
    } %}

    {% if widgets.live_viewers is defined %}
        {% set lv_pos = widgets.live_viewers.position|default('bottom_right') %}
        <div style="position:fixed;{{ pos_css[lv_pos]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9998;{{ pill }}"
             data-controller="{{ ctrl_prefix }}/live-viewers"
             data-{{ ctrl_ns }}--live-viewers-url-value="{{ path('social_proof_shop_live_viewers', {productId: product.id}) }}"
             data-{{ ctrl_ns }}--live-viewers-interval-value="{{ (widgets.live_viewers.settings.refresh_interval|default(30)) * 1000 }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#3b82f6;flex-shrink:0;">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <span>
                <strong data-{{ ctrl_ns }}--live-viewers-target="count">{{ widgets.live_viewers.count }}</strong>
                {{ 'social_proof.shop.people_viewing'|trans }}
            </span>
        </div>
    {% endif %}

    {% if rp_settings is not empty %}
        {% set rp_pos = rp_settings.display_position|default('bottom_right') %}
        <div id="sp-notification" style="position:fixed;{{ pos_css[rp_pos]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9997;{{ pill }}display:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <span id="sp-message"></span>
            <button onclick="spDismiss()" style="background:none;border:none;color:#9ca3af;cursor:pointer;font-size:1rem;padding:0;line-height:1;flex-shrink:0;">&times;</button>
        </div>
    {% endif %}

    {% if widgets.sales_counter is defined %}
        {% set sc_pos = widgets.sales_counter.position|default('bottom_right') %}
        <div style="position:fixed;{{ pos_css[sc_pos]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9996;{{ pill }}"
             data-controller="{{ ctrl_prefix }}/sales-counter"
             data-{{ ctrl_ns }}--sales-counter-count-value="{{ widgets.sales_counter.count }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#f59e0b;flex-shrink:0;">
                <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"></path>
            </svg>
            <span>
                <strong data-{{ ctrl_ns }}--sales-counter-target="count">0</strong>
                {{ 'social_proof.shop.sold_recently'|trans({'%hours%': widgets.sales_counter.lookback_hours}) }}
            </span>
        </div>
    {% endif %}

    {% if widgets.low_stock is defined %}
        {% set ls_pos = widgets.low_stock.position|default('bottom_right') %}
        <div style="position:fixed;{{ pos_css[ls_pos]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9995;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:0.5rem 0.875rem;box-shadow:0 2px 12px rgba(0,0,0,0.1);font-size:0.8125rem;color:#dc2626;font-weight:600;display:flex;align-items:center;gap:0.5rem;"
             data-controller="{{ ctrl_prefix }}/low-stock"
             data-{{ ctrl_ns }}--low-stock-count-value="{{ widgets.low_stock.count }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span>{{ 'social_proof.shop.only_left'|trans({'%count%': widgets.low_stock.count}) }}</span>
        </div>
    {% endif %}

    {% if widgets.custom_message is defined %}
        {% set cm = widgets.custom_message %}
        {% set cm_pos = cm.position|default('bottom_right') %}
        <div id="sp-custom-message" style="position:fixed;{{ pos_css[cm_pos]|default('bottom:1.5rem;right:1.5rem;') }}z-index:9994;{{ pill }}max-width:340px;">
            <span style="flex-shrink:0;">{{ cm.icon|e('html') }}</span>
            <span>
                {{ cm.message|e('html') }}
                {% if cm.link_url and cm.link_text %}
                    <a href="{{ cm.link_url|e('html_attr') }}" style="color:inherit;font-weight:600;text-decoration:underline;margin-left:0.25rem;">{{ cm.link_text|e('html') }}</a>
                {% endif %}
            </span>
            {% if cm.dismissible %}
                <button onclick="this.parentElement.style.display='none';try{sessionStorage.setItem('sp_custom_dismissed','1')}catch(e){}" style="background:none;border:none;color:#9ca3af;cursor:pointer;font-size:1rem;padding:0;line-height:1;flex-shrink:0;">&times;</button>
            {% endif %}
        </div>
        <script>
        (function(){try{if(sessionStorage.getItem('sp_custom_dismissed')){var e=document.getElementById('sp-custom-message');if(e)e.style.display='none';}}catch(e){}})();
        </script>
    {% endif %}

    {% if rp_settings is not empty %}
        <script>
        (function() {
            var storageKey = 'sp_recent_purchases_shown';
            try { if (sessionStorage.getItem(storageKey)) return; } catch(e) {}

            var url = '{{ path('social_proof_shop_recent_purchases')|e('js') }}';
            var interval = {{ (rp_settings.display_interval|default(8)) * 1000 }};
            var max = {{ rp_settings.max_toasts|default(5) }};
            var purchases = [], idx = 0;
            var el = document.getElementById('sp-notification');
            if (!el) return;

            function timeAgo(d) {
                if (!d) return '';
                var diff = Math.floor((Date.now() - new Date(d).getTime()) / 60000);
                if (diff < 1) return 'just now';
                if (diff < 60) return diff + 'm ago';
                var h = Math.floor(diff / 60);
                return h < 24 ? h + 'h ago' : Math.floor(h / 24) + 'd ago';
            }

            function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

            function show() {
                if (idx >= purchases.length || idx >= max) return;
                var p = purchases[idx];
                var city = p.city ? ' from ' + esc(p.city) : '';
                var name = esc(p.first_name || 'Someone');
                var msg = document.getElementById('sp-message');
                var time = timeAgo(p.purchased_at);
                var timeHtml = time ? ' <span style="color:#9ca3af;">' + esc(time) + '</span>' : '';
                var productUrl = p.product_slug ? '/' + encodeURI(p.locale + '/products/' + p.product_slug) : '';
                if (msg) {
                    var productHtml = productUrl
                        ? '<a href="' + esc(productUrl) + '" style="color:inherit;font-weight:600;text-decoration:underline;">' + esc(p.product_name) + '</a>'
                        : '<strong>' + esc(p.product_name) + '</strong>';
                    msg.innerHTML = name + city + ' just bought ' + productHtml + timeHtml;
                }
                el.style.display = 'flex';
                setTimeout(function() { el.style.display = 'none'; idx++; setTimeout(show, 2000); }, interval);
            }

            window.spDismiss = function() { el.style.display = 'none'; idx++; try { sessionStorage.setItem(storageKey, '1'); } catch(e) {} };

            fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                purchases = data;
                if (purchases.length > 0) { try { sessionStorage.setItem(storageKey, '1'); } catch(e) {} setTimeout(show, 3000); }
            }).catch(function() {});
        })();
        </script>
    {% endif %}
{% endif %}
